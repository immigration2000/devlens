# ===========================
# DevLens Environment Variables
# ===========================
# Copy this file to .env and fill in the values
# [필수] 표시 항목은 반드시 설정해야 합니다.
# 나머지 인프라 접속 정보는 기본값이 Docker Compose 설정과 일치합니다.

# --- App ---
NODE_ENV=development
PORT_WEB=3000
PORT_API=4000

# --- Auth ---
JWT_SECRET=your-jwt-secret-change-me          # [필수] 랜덤 시크릿 키
GITHUB_CLIENT_ID=                              # GitHub OAuth 로그인 시 필요
GITHUB_CLIENT_SECRET=                          # GitHub OAuth 로그인 시 필요
GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback
FRONTEND_URL=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# --- AI ---
ANTHROPIC_API_KEY=                             # [필수] Claude API 키 (sk-ant-...)
OPENAI_API_KEY=                                # 선택 (대체 LLM)

# --- Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=devlens-api

# --- Supabase ---
SUPABASE_URL=http://localhost:54321
SUPABASE_KEY=your-supabase-anon-key

# --- ClickHouse ---
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_DATABASE=devlens
CLICKHOUSE_USER=devlens
CLICKHOUSE_PASSWORD=devlens_local
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=devlens

# --- PostgreSQL ---
DATABASE_URL=postgresql://devlens:devlens_local@localhost:5432/devlens

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=devlens-snapshots
R2_ENDPOINT=

# --- ML Server ---
ML_SERVER_URL=http://localhost:8000

# --- Sandbox ---
SANDBOX_URL=http://localhost:4001
SANDBOX_HOST=0.0.0.0
SANDBOX_PORT=4001
DOCKER_SOCKET=/var/run/docker.sock

# --- Worker ---
WORKER_CONCURRENCY=3
LOG_LEVEL=info
