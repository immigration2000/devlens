{
  "name": "@devlens/ai-engine",
  "version": "1.0.0",
  "type": "module",
  "description": "AI analysis engine for DevLens",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc || echo 'ai-engine: type errors exist but JS emitted'",
    "start": "node dist/index.js",
    "lint": "eslint src/ --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "echo \"No tests yet\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "kafkajs": "^2.2.4",
    "bullmq": "^5.0.0",
    "ioredis": "^5.3.2",
    "@anthropic-ai/sdk": "^0.24.0",
    "@clickhouse/client": "^0.2.1",
    "dotenv": "^16.3.1",
    "@devlens/shared": "workspace:*"
  },
  "devDependencies": {
    "@devlens/tsconfig": "workspace:*",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "@types/node": "^20.10.6",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  }
}
